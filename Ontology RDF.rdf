     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:ship="http://snomed.info/id/224673002"
     xmlns:tour="https://tourism-onto.org/ont#"
     xmlns:group="http://www.w3.org/2006/vcard/ns#Group#"
     xmlns:unece="http://unece.org/vocab#"
     xmlns:ground="http://purl.obolibrary.org/obo/ENVO_03501351#"
     xmlns:schema="https://schema.org/"
     xmlns:single="http://purl.obolibrary.org/obo/NCIT_C48440#"
     xmlns:medtour="http://purl.obolibrary.org/obo/gsso.owl"
     xmlns:schema1="http://schema.org/"
     xmlns:airplane="http://purl.obolibrary.org/obo/ENVO_03501349#"
     xmlns:histsite="http://purl.obolibrary.org/obo/gsso.owl#"
     xmlns:bioportal="http://www.w3.org/2002/07/owl#Class#"
     xmlns:tourguide="http://purl.obolibrary.org/obo/OCCO_39701100#"
     xmlns:NCIThiking="http://purl.obolibrary.org/obo/ncit.owl#"
     xmlns:TourismOLs="https://w3id.org/biopragmatics/resources/mesh/mesh.ofnhttps://w3id.org/biopragmatics/resources/mesh/mesh.ofn#"
     xmlns:snomedfarm="http://snomed.info/sct/9000000000002070081231#"
     xmlns:activityOLS="http://www.w3.org/ns/dcat#"
     xmlns:travelagent="http://purl.obolibrary.org/obo/OCCO_41304100#"
     xmlns:watersports="https://w3id.org/biopragmatics/resources/mesh/mesh.ofn"
     xmlns:organization="http://schema.org/Organization#">
    <Ontology rdf:about="https://tourism-onto.org/ont">
        <dc:creator>Tourism Ontology Group
BSCS51F23S002 (Barira)
BSCS51F23S031 (Mishal)</dc:creator>
        <dc:title>Tourism Ontology</dc:title>
    </Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/elements/1.1/creator -->

    <AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/date -->

    <AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/date"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->

    <AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://schema.org/broker -->

    <ObjectProperty rdf:about="http://schema.org/broker">
        <inverseOf rdf:resource="https://tourism-onto.org/ont#bookedBy"/>
        <rdfs:domain>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OCCO_41304100"/>
                    <rdf:Description rdf:about="https://tourism-onto.org/ont#TourismActor"/>
                </unionOf>
            </Class>
        </rdfs:domain>
        <rdfs:range>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://schema.org/Reservation"/>
                    <rdf:Description rdf:about="http://schema.org/Ticket"/>
                </unionOf>
            </Class>
        </rdfs:range>
    </ObjectProperty>
    


    <!-- http://schema.org/containsPlace -->

    <ObjectProperty rdf:about="http://schema.org/containsPlace">
        <rdfs:domain rdf:resource="http://id.nlm.nih.gov/mesh/D000085926"/>
        <rdfs:range>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://schema.org/TouristAttraction"/>
                    <rdf:Description rdf:about="http://schema.org/TouristDestination"/>
                </unionOf>
            </Class>
        </rdfs:range>
    </ObjectProperty>
    


    <!-- http://schema.org/makesOffer -->

    <ObjectProperty rdf:about="http://schema.org/makesOffer">
        <rdfs:domain rdf:resource="http://schema.org/TravelAgency"/>
        <rdfs:range rdf:resource="https://tourism-onto.org/ont#TourismActivity"/>
    </ObjectProperty>
    


    <!-- http://schema.org/provider -->

    <ObjectProperty rdf:about="http://schema.org/provider">
        <rdfs:domain rdf:resource="http://schema.org/TravelAgency"/>
        <rdfs:range rdf:resource="http://schema.org/Reservation"/>
    </ObjectProperty>
    


    <!-- https://tourism-onto.org/ont#bookedBy -->

    <ObjectProperty rdf:about="https://tourism-onto.org/ont#bookedBy">
        <rdfs:domain>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://schema.org/Reservation"/>
                    <rdf:Description rdf:about="http://schema.org/Ticket"/>
                </unionOf>
            </Class>
        </rdfs:domain>
        <rdfs:range>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OCCO_41304100"/>
                    <rdf:Description rdf:about="https://tourism-onto.org/ont#TourismActor"/>
                </unionOf>
            </Class>
        </rdfs:range>
    </ObjectProperty>
    


    <!-- https://tourism-onto.org/ont#guidedBy -->

    <ObjectProperty rdf:about="https://tourism-onto.org/ont#guidedBy">
        <rdfs:domain rdf:resource="https://tourism-onto.org/ont#TourismActor"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/OCCO_39701100"/>
    </ObjectProperty>
    


    <!-- https://tourism-onto.org/ont#hasAccomodation -->

    <ObjectProperty rdf:about="https://tourism-onto.org/ont#hasAccomodation">
        <rdfs:domain>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://schema.org/Reservation"/>
                    <rdf:Description rdf:about="https://tourism-onto.org/ont#TourismActor"/>
                </unionOf>
            </Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://schema.org/Accommodation"/>
    </ObjectProperty>
    


    <!-- https://tourism-onto.org/ont#hasDestination -->

    <ObjectProperty rdf:about="https://tourism-onto.org/ont#hasDestination">
        <rdfs:domain>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://schema.org/Vehicle"/>
                    <rdf:Description rdf:about="https://tourism-onto.org/ont#TourismActor"/>
                </unionOf>
            </Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://schema.org/TouristDestination"/>
    </ObjectProperty>
    


    <!-- https://tourism-onto.org/ont#hasEmployee -->

    <ObjectProperty rdf:about="https://tourism-onto.org/ont#hasEmployee">
        <inverseOf rdf:resource="https://tourism-onto.org/ont#worksFor"/>
        <rdfs:domain rdf:resource="http://schema.org/TravelAgency"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/OCCO_39701100"/>
    </ObjectProperty>
    


    <!-- https://tourism-onto.org/ont#hasMembers -->

    <ObjectProperty rdf:about="https://tourism-onto.org/ont#hasMembers">
        <inverseOf rdf:resource="https://tourism-onto.org/ont#memberOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2006/vcard/ns#Group"/>
        <rdfs:range rdf:resource="https://tourism-onto.org/ont#Tourist"/>
    </ObjectProperty>
    


    <!-- https://tourism-onto.org/ont#hasPolicy -->

    <ObjectProperty rdf:about="https://tourism-onto.org/ont#hasPolicy">
        <inverseOf rdf:resource="https://tourism-onto.org/ont#isPolicyOf"/>
        <rdfs:domain rdf:resource="http://id.nlm.nih.gov/mesh/D000085926"/>
        <rdfs:range rdf:resource="http://purl.org/dc/terms/Policy"/>
    </ObjectProperty>
    


    <!-- https://tourism-onto.org/ont#hasRating -->

    <ObjectProperty rdf:about="https://tourism-onto.org/ont#hasRating">
        <rdfs:domain>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://schema.org/Accommodation"/>
                    <rdf:Description rdf:about="http://schema.org/TouristAttraction"/>
                    <rdf:Description rdf:about="http://schema.org/TouristDestination"/>
                    <rdf:Description rdf:about="http://schema.org/TravelAgency"/>
                </unionOf>
            </Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://schema.org/Rating"/>
    </ObjectProperty>
    


